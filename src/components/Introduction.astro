---
import BlazejCzarusia from "../assets/images/blazej_czarusia.jpg";
import Wave from "../assets/images/wave_sketch.png";
import Smile from "../assets/images/smile_sketch.png";
---

<div class="introduction">
  <div class="introduction__wrapper">
    <div class="description">
      <div class="description__top__row__wrapper">
        <div class="wave"><img src={Wave.src} alt="Wave" /></div>
        <div class="red__box"></div>
      </div>
      <div class="greeting__wrapper">
        Cześć <div class="line__greeting"></div>
      </div>
      <div class="about__me__text">
        <p>Nazywam się Błażej Wilczyński.</p>
        <p>Piszę książki i tworzę grafikę.</p>
        <p>Gwarantuję zwroty akcji, suchary oraz dużo kolorków.</p>
        <p>
          W wolnych chwilach gram na gitarze utwory zespołów Metallica,
          The Police, Durry oraz Highly Suspect.
        </p>
      </div>
      <div class="smile__wrapper">
        <img src={Smile.src} alt="Wave" />
      </div>
      <div class="line__under__smile"></div>
      <div class="button__wrapper">
        <a href="#books" class="button__start">
          <span>Zaczynamy</span>
        </a>
      </div>
    </div>
  </div>
  <div class="photo__wrapper">
    <div class="photo__bobek">
      <img src={BlazejCzarusia.src} alt="Błażej Czarusia" />
    </div>
  </div>
</div>

<style>
  .introduction {
    height: 900px;
    width: 100%;
    display: flex;
  }

  .introduction__wrapper {
    width: 50%;
    height: 100%;
    background-color: #f7f1eb;
    display: flex;
  }

  .photo__wrapper {
    width: 50%;
    height: 100%;
    background-color: #121212;
    display: flex;
  }

  .description {
    height: 100%;
    width: 100%;
    max-width: 590px;
    /* background-color: lightpink;  */
    margin-left: auto;
    box-sizing: border-box;
    padding: 45px;
  }

  .photo__bobek {
    height: 100%;
    width: 100%;
    /* max-width: 590px; */
    background-color: lightgray;
    margin-right: auto;
    overflow: hidden;
    position: relative;
  }

  .photo__bobek img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    position: absolute;
    object-position: center 15%;
  }

  .description__top__row__wrapper {
    height: 60px;
    width: 100%;
    /* background-color: aquamarine; */
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .red__box {
    height: 40px;
    width: 40px;
    background-color: var(--red-base);
  }

  .greeting__wrapper {
    display: inline-flex;
    align-items: flex-end;
    gap: 12px;
    font-weight: 400;
    font-size: 2.4rem;
    margin-top: 80px;
  }

  .line__greeting {
    height: 3px;
    flex: 1;
    width: 340px;
    margin-bottom: 10px;
    background: var(--base-text-color);
    max-width: 340px;
  }

  .about__me__text {
    margin-top: 60px;
    max-width: 440px;
    line-height: 1.5;
  }

  .about__me__text p {
    margin-block-start: 0;
    margin-block-end: 0;
    font-size: 1.6rem;
  }

  .smile__wrapper {
    width: 100%;
    margin-top: 60px;
    display: flex;
    justify-content: flex-end;
  }

  .smile__wrapper img {
    height: 65px;
    padding-right: 100px;
  }

  .line__under__smile {
    height: 3px;
    width: 200px;
    margin-bottom: 10px;
    background: var(--base-text-color);
    margin-left: auto;
    margin-right: 30px;
    margin-top: 5px;
  }

  .button__wrapper {
    width: 100%;
    /* height: 20px; */
    /* background-color: lightsalmon; */
    display: flex;
    justify-content: flex-end;
    padding-right: 30px;
    margin-top: 50px;
  }

  /* ======================== Button Styling ========================= */

  .button__start {
    position: relative;
    padding: 20px 52px;
    font-family: "DM Sans", sans-serif;
    font-size: 1.2rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: #fff;
    background: #e8415a;
    border: none;
    cursor: pointer;
    overflow: hidden;
    outline: none;
    transition: color 0.35s ease;
  }

  /* Sliding fill overlay */
  .button__start::before {
    content: "";
    position: absolute;
    inset: 0;
    background: #1a1a1a;
    transform: translateX(-101%);
    transition: transform 0.45s cubic-bezier(0.77, 0, 0.175, 1);
    z-index: 0;
  }

  .button__start:hover::before {
    transform: translateX(0);
  }

  /* Sparkle particles */
  .button__start::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle, #fff 1px, transparent 1px),
      radial-gradient(circle, #fff 1px, transparent 1px),
      radial-gradient(circle, #fff 1px, transparent 1px);
    background-size: 8px 8px;
    background-position:
      20% 40%,
      60% 20%,
      80% 70%;
    opacity: 0;
    transition: opacity 0.3s ease 0.2s;
    z-index: 1;
    pointer-events: none;
  }

  .button__start:hover::after {
    opacity: 0.12;
  }

  .button__start span {
    position: relative;
    z-index: 2;
    display: inline-block;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .button__start:hover span {
    transform: scale(1.06);
  }

  /* Shadow lift */
  .button__start {
    box-shadow: 4px 4px 0px #c52d44;
    transition:
      box-shadow 0.2s ease,
      transform 0.2s ease,
      color 0.35s ease;
  }

  .button__start:hover {
    box-shadow: 8px 8px 0px #111;
    transform: translate(-2px, -2px);
  }

  .button__start:active {
    box-shadow: 2px 2px 0px #111;
    transform: translate(2px, 2px);
  }

  /* ======================== End of Button Styling ========================= */

  /* ---------------------------- 1280 px ---------------------------------- */

  @media (max-width: 1280px) {
    .description {
      padding-left: 80px;
    }
  }

  /* ---------------------------- 768 px ---------------------------------- */

  @media (max-width: 768px) {
    .introduction {
      flex-direction: column;
      height: auto;
    }

    .introduction__wrapper {
      width: 100%;
    }

    .description {
      margin: 0 auto;
      max-width: 500px;
      padding: 30px 20px;
    }

    .photo__wrapper {
      width: 100%;
      height: 800px; /* ustaw według potrzeb */
    }

    .line__greeting {
      width: 290px;
    }
  }
</style>
